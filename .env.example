# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults in app/config.py, so .env is optional
# for local development — it's here mainly to document what's configurable.

# Base directory where all runtime data (uploads, models, reports) is stored.
# Relative paths are resolved from the project root.
DATA_DIR=data

# SQLite database file path (relative to project root).
DATABASE_URL=sqlite:///./autoinsight.db

# Maximum allowed upload size, in megabytes.
MAX_UPLOAD_SIZE_MB=50

# Allowed uploaded file extensions (comma-separated, no dots).
ALLOWED_EXTENSIONS=csv,xlsx,xls

# Default time budget (in seconds) for AutoML hyperparameter search per algorithm.
AUTOML_TUNING_TIME_BUDGET_SECONDS=60

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
